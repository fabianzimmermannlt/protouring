# ProTouring – Umgebungsvariablen
# Kopieren als .env und Werte eintragen

# ── Server ────────────────────────────────────────────────
# Zufälliger, langer String (Produktion: mindestens 64 Zeichen)
# Generieren mit: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=HIER_EINEN_LANGEN_ZUFALLSSTRING_EINTRAGEN

# Port des Express-API-Servers (Default: 3002)
PORT=3002

# ── Frontend ──────────────────────────────────────────────
# Lokal:
NEXT_PUBLIC_API_URL=http://localhost:3002
# Produktion (Beispiel):
# NEXT_PUBLIC_API_URL=https://deine-domain.de/api

# Erlaubte CORS-Origin für den API-Server
# Lokal:
FRONTEND_URL=http://localhost:3000
# Produktion:
# FRONTEND_URL=https://deine-domain.de

# ── Datenbank ─────────────────────────────────────────────
# Pfad zur SQLite-Datei (optional, Default: ./protouring.db)
# DB_PATH=./protouring.db
